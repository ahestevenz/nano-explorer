#!/usr/bin/env python3
"""
nano-explorer -- Modular CLI for the Waveshare JetBot / Jetson Nano B01.

Usage:
  nano-explorer motion    <command> [options]
  nano-explorer vision   <command> [options]
  nano-explorer nav      <command> [options]
  nano-explorer ml       <command> [options]
  nano-explorer --help
  nano-explorer --version
"""

# OpenBLAS / numpy SIGILL fix
# MUST be set before any numpy/torch import on Jetson Nano (Maxwell / ARMv8).
# pip-installed numpy wheels bundle OpenBLAS compiled with AVX2 which the
# Cortex-A57 does not support.  Forcing ARMV8 prevents the illegal instruction.
import os

os.environ.setdefault("OPENBLAS_CORETYPE", "ARMV8")

import argparse
import sys

from colorama import Fore, Style, init

from lib.settings import NanoSettings

init(autoreset=True)

BANNER = (
    Fore.CYAN
    + r"""
  ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
  ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó
  ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ
  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ
  ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
  ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
  """
    + Fore.WHITE
    + Fore.RED
    + Style.BRIGHT
    + "  E X P L O R E R\n"
    + Style.RESET_ALL
)


def build_parser(settings: NanoSettings):
    parser = argparse.ArgumentParser(
        prog="nano-explorer",
        description="Modular CLI toolkit for the Waveshare JetBot.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--version", action="version", version="nano-explorer 0.1.0")

    subparsers = parser.add_subparsers(
        dest="group",
        metavar="GROUP",
        help="Command group",
    )
    subparsers.required = True

    # Imports are deliberately deferred to here (not module-level) so that
    # OPENBLAS_CORETYPE is already set before any transitive numpy import.

    # Motion operations
    from commands.motion import register as register_motion

    motion_parser = subparsers.add_parser(
        "motion",
        help="robot motion, streaming and collision avoidance",
    )
    register_motion(motion_parser, settings)

    # Computer vision
    from commands.vision import register as register_vision  # pylint: disable=E0611, E0401

    vision_parser = subparsers.add_parser(
        "vision",
        help="Object detection, tracking, segmentation, pose estimation",
    )
    register_vision(vision_parser, settings)

    # Navigation & mapping
    from commands.cmd_navigation import register as register_nav  # pylint: disable=E0611, E0401

    nav_parser = subparsers.add_parser(
        "nav",
        help="[Experimental] Line/road following, SLAM, AprilTag navigation",
    )
    register_nav(nav_parser)

    # Machine learning
    from commands.cmd_ml import register as register_ml  # pylint: disable=E0611, E0401

    ml_parser = subparsers.add_parser(
        "ml",
        help="[Experimental] Behaviour cloning -- record, train, deploy",
    )
    register_ml(ml_parser)

    return parser


def main():
    print(BANNER)
    settings = NanoSettings()
    parser = build_parser(settings)
    args = parser.parse_args()

    if hasattr(args, "func"):
        try:
            args.func(args)
        except KeyboardInterrupt:
            print(Fore.YELLOW + "\n[nano-explorer] Interrupted by user.")
            sys.exit(0)
        except Exception as exc:
            print(Fore.RED + f"\n[nano-explorer] Fatal error: {exc}")
            raise
    else:
        parser.print_help()


if __name__ == "__main__":
    main()

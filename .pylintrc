[MASTER]
# Use multiple processes to speed up pylint
jobs = 2

# Add lib/ and commands/ to the Python path so pylint resolves imports
init-hook = "import sys; sys.path.insert(0, '.')"

[MESSAGES CONTROL]
# Disable messages that are noisy or conflict with our style choices
disable =
    # Too opinionated / style
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    C0301,  # line-too-long (black handles this)
    C0303,  # trailing-whitespace (pre-commit handles this)
    C0411,  # wrong-import-order (ruff/isort handles this)

    # Jetson Nano hardware — optional imports are expected to fail
    W0611,  # unused-import (false positives on lazy imports)
    W0612,  # unused-variable

    # Too strict for a robotics project
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    W0212,  # protected-access (we access _private in tests)
    W0703,  # broad-except (intentional in hardware error handlers)

    # Python 3.6 compatibility — these fire on f-strings with = specifier etc.
    W0107,  # unnecessary-pass

[FORMAT]
max-line-length = 100
indent-string = "    "

[DESIGN]
max-args = 10
max-attributes = 15
max-bool-expr = 6
max-branches = 15
max-returns = 8
max-statements = 60

[SIMILARITIES]
# Minimum lines to consider as duplicate code
min-similarity-lines = 8
ignore-comments = yes
ignore-docstrings = yes

[TYPECHECK]
# Modules that pylint cannot import on a non-Nano machine
ignored-modules =
    jetbot,
    jetson,
    board,
    busio,
    adafruit_pca9685,
    adafruit_motor,
    cv2,
    torch,
    torchvision,
    trt_pose,
    torch2trt,
    pynput,
    apriltag,

ignored-classes =
    jetbot.Robot,
